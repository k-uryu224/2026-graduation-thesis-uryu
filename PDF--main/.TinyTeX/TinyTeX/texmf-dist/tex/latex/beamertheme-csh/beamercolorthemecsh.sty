\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{beamercolorthemecsh}[2025/11/27 v1.1 CSH Beamer Color Theme]

\mode<presentation>

% CSH Brand Colors with generic names
\definecolor{primary}{RGB}{0,97,210}        % CSH blue
\definecolor{secondary}{RGB}{69,137,255}    % CSH medium blue
\definecolor{tertiary}{RGB}{183,225,255}    % CSH light blue
\definecolor{dark}{RGB}{0,0,0}              % Black
\definecolor{light}{RGB}{235,236,237}       % Light gray
\definecolor{accent}{RGB}{162,169,176}      % CSH dark gray

% Beamer color scheme
\setbeamercolor*{palette primary}{fg=accent}
\setbeamercolor*{palette secondary}{fg=accent}
\setbeamercolor*{palette tertiary}{fg=accent}
\setbeamercolor*{palette quaternary}{fg=accent}

\setbeamercolor{normal text}{fg=dark}

\setbeamercolor*{title page header}{fg=dark}
\setbeamercolor*{author}{fg=dark}
\setbeamercolor*{date}{fg=dark}
\setbeamercolor{alerted text}{fg=secondary}

\setbeamercolor{caption name}{fg=dark}
\setbeamercolor{description item}{fg=accent}
\setbeamercolor{titlelike}{fg=dark}
\setbeamercolor{frametitle}{fg=dark}
\setbeamercolor{framesubtitle}{fg=dark}

\setbeamercolor{block title}{fg=dark}
\setbeamercolor{block title alerted}{fg=primary}
\setbeamercolor{block title example}{fg=dark}

\setbeamercolor{itemize item}{fg=dark}
\setbeamercolor{itemize subitem}{fg=dark}
\setbeamercolor{itemize subsubitem}{fg=dark}
\setbeamercolor{enumerate item}{fg=dark}
\setbeamercolor{enumerate subitem}{fg=dark}
\setbeamercolor{enumerate subsubitem}{fg=dark}

\setbeamercolor{section in toc}{fg=dark}
\setbeamercolor{subsection in toc}{fg=dark}

\setbeamercolor*{bibliography entry title}{fg=dark}
\setbeamercolor*{bibliography entry author}{fg=dark}
\setbeamercolor*{bibliography entry journal}{fg=dark}
\setbeamercolor*{bibliography entry location}{fg=dark}
\setbeamercolor*{bibliography entry note}{fg=dark}
\setbeamercolor*{bibliography item}{fg=dark}

\mode<all>
